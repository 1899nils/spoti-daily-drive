# Copy this to .env and fill in your values
# Get credentials from https://developer.spotify.com/dashboard

SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Set this to your server's address + /auth/callback
# WICHTIG: Spotify erlaubt HTTP nur für localhost.
# Für Heimserver (Unraid, NAS, etc.) https:// mit lokaler IP verwenden –
# Spotify akzeptiert das, auch ohne echtes SSL-Zertifikat.
# Der Browser kann die Seite dann zwar nicht laden, aber die URL mit
# ?code=... ist in der Adressleiste sichtbar und kann kopiert werden.
#
# Beispiele:
#   Lokal (gleicher Rechner): http://localhost:8080/auth/callback
#   Heimserver:               https://192.168.1.x:8080/auth/callback
SPOTIFY_REDIRECT_URI=https://192.168.1.x:8080/auth/callback
